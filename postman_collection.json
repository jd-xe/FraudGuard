          "raw": "{\r\n  \"userId\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\r\n  \"merchantId\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\r\n  \"amount\": 150.0,\r\n  \"ipAddress\": \"192.168.1.1\",\r\n  \"originCountry\": \"PE\"\r\n}",
