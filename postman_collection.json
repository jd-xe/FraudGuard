    {
      "name": "2. Get Suspicious Audits",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Data is an array and pagination exists\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property('data');\r",
              "    pm.expect(jsonData.data).to.be.an('array');\r",
              "    pm.expect(jsonData.page).to.eql(1);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5053/api/audits/suspicious?page=1&pageSize=10",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5053",
          "path": [
            "api",
            "audits",
            "suspicious"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "pageSize",
              "value": "10"
